# Streamlit secrets template — for deployment on Streamlit Community Cloud.
#
# Locally the app reads the LunarCrush key from the .env file, so you do NOT
# need a secrets.toml on your own machine.
#
# When deploying: in your app on share.streamlit.io, open
#   Settings -> Secrets
# and paste the line below WITH your real key. Never commit a real
# secrets.toml — it is git-ignored.

LUNARCRUSH_API_KEY = "your-lunarcrush-key-here"
